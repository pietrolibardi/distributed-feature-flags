# Copie este arquivo para .env e ajuste os valores antes de rodar Docker ou o script de smoke test:
#   cp .env.example .env
#
# O docker-compose usa essas variáveis. JWT_SECRET é obrigatório em produção.

JWT_SECRET=your-secret-key-change-in-production
# Opcional; valor em milissegundos (padrão: 3600000 = 1 hora)
# JWT_EXPIRATION=3600000
